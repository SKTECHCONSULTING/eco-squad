      "method": "DELETE",
      "status": "COMPLETE",
      "description": "Delete mission (admin only)"
    },
    {
      "path": "/api/missions/:id/claim",
      "method": "POST",
      "status": "COMPLETE",
      "description": "Claim mission with transaction safety and expiry"
    },
    {
      "path": "/api/missions/:id/submit-evidence",
      "method": "POST",
      "status": "COMPLETE",
      "description": "Submit evidence with location validation"
    },
    {
      "path": "/api/squads",
      "method": "GET",
      "status": "COMPLETE",
      "description": "List squads with optional user filter"
    },
    {
      "path": "/api/squads",
      "method": "POST",
      "status": "COMPLETE",
      "description": "Create new squad"
    },
    {
      "path": "/api/squads/:id",
      "method": "GET",
      "status": "COMPLETE",
      "description": "Get squad details"
