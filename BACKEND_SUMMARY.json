{
  "endpointsImplemented": [
    {
      "path": "/api/missions",
      "method": "GET",
      "status": "COMPLETE",
      "description": "Discover nearby missions with geohash-based queries"
    },
    {
      "path": "/api/missions",
      "method": "POST",
      "status": "COMPLETE",
      "description": "Create new mission (admin/org only)"
    },
    {
