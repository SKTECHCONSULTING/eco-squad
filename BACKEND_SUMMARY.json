    {
      "path": "/api/squads/:id/members",
      "method": "GET",
      "status": "COMPLETE",
      "description": "List squad members"
    },
    {
      "path": "/api/squads/:id/members",
      "method": "POST",
      "status": "COMPLETE",
      "description": "Add member to squad"
    },
    {
      "path": "/api/squads/:id/members",
      "method": "DELETE",
      "status": "COMPLETE",
      "description": "Remove member from squad"
    },
    {
      "path": "/api/auth/[...nextauth]",
      "method": "GET|POST",
      "status": "COMPLETE",
      "description": "Cognito authentication handler"
    }
