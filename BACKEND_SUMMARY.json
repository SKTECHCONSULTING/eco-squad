    },
    {
      "name": "Rate Limiting",
      "file": "src/lib/middleware/rate-limit.ts",
      "features": ["In-memory store", "Configurable limits", "Rate limit headers"]
    },
    {
      "name": "Validation",
      "file": "src/lib/middleware/validation.ts",
      "features": ["Zod schemas", "Body/query/param validation", "Input sanitization"]
    }
  ],
  "services": [
    {
