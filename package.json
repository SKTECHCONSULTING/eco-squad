{
  "name": "eco-squad",
  "version": "1.0.0",
  "description": "EcoSquad - Environmental Micro-Volunteering Platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "validate": "node scripts/validate-env.js",
    "build:all": "./scripts/build.sh all",
    "build:frontend": "./scripts/build.sh frontend",
    "build:backend": "./scripts/build.sh backend",
    "build:infra": "./scripts/build.sh infra",
    "db:setup": "cd infra && npm run setup",
    "deploy:dev": "ENVIRONMENT=dev ./scripts/build.sh all && cd infra && npm run deploy",
    "deploy:prod": "ENVIRONMENT=prod ./scripts/build.sh all && cd infra && npm run deploy && ./scripts/deploy-frontend.sh",
    "deploy:infra": "cd infra && npm run deploy",
    "deploy:frontend": "./scripts/deploy-frontend.sh",
    "deploy:all": "npm run build && npm run deploy:infra && npm run deploy:frontend",
    "synth": "cd infra && npm run synth",
    "bootstrap": "cd infra && npm run bootstrap",
    "docker:dev": "docker-compose up",
    "docker:build": "docker-compose build",
    "docker:down": "docker-compose down -v",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-rekognition": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@hookform/resolvers": "^5.2.2",
    "@types/leaflet": "^1.9.21",
    "aws-jwt-verify": "^4.0.1",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "leaflet": "^1.9.4",
    "next": "^14.2.0",
    "next-auth": "^4.24.13",
    "ngeohash": "^0.6.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.0",
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
